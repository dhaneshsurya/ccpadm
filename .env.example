SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,13.49.229.197,csaconline.in,www.csaconline.in,online.chaitanyacg.ac.in

# SQL Server source (for import_from_sqlserver command)
MSSQL_SERVER=.\SQLEXPRESS
MSSQL_CCPDB=ccpdb
MSSQL_COURSEDB=courseinformation
MSSQL_TRUSTED_CONNECTION=yes

# ---------------------------------------------------------------------------
# Email — Amazon SES (recommended for production)
# ---------------------------------------------------------------------------
USE_SES=True
AWS_SES_REGION_NAME=ap-south-1
# Must be a verified identity in SES (domain or email):
DEFAULT_FROM_EMAIL=noreply@chaitanyacg.ac.in

# On EC2: attach an IAM role with ses:SendEmail + ses:SendRawEmail (preferred).
# Or set IAM user keys here:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ---------------------------------------------------------------------------
# Email — Gmail SMTP (fallback / local dev only)
# ---------------------------------------------------------------------------
# USE_SES=False
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=onlinecsac@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password-here
# DEFAULT_FROM_EMAIL=onlinecsac@gmail.com